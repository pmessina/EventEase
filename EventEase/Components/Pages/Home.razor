@page "/"

<PageTitle>Home - EventEase</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <h1 class="hero-title">Welcome to EventEase</h1>
        <p class="hero-subtitle">Your premier platform for corporate and social event management</p>
        <p class="hero-description">
            Discover, register, and manage your attendance for exciting events ranging from 
            technology summits to charity galas. EventEase makes event participation seamless and enjoyable.
        </p>
        <div class="hero-actions">
            <a href="/events" class="btn btn-primary btn-lg">
                <span class="bi bi-calendar-event"></span> Browse Events
            </a>
            <a href="/events" class="btn btn-outline-light btn-lg">
                Learn More
            </a>
        </div>
    </div>

    <div class="features-section">
        <h2>Why Choose EventEase?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <span class="bi bi-search feature-icon"></span>
                <h3>Easy Discovery</h3>
                <p>Browse and search through a curated collection of corporate and social events tailored to your interests.</p>
            </div>
            <div class="feature-card">
                <span class="bi bi-lightning-charge feature-icon"></span>
                <h3>Quick Registration</h3>
                <p>Register for events in seconds with our streamlined registration process and instant confirmations.</p>
            </div>
            <div class="feature-card">
                <span class="bi bi-bell feature-icon"></span>
                <h3>Stay Updated</h3>
                <p>Receive timely notifications and updates about your registered events and new opportunities.</p>
            </div>
            <div class="feature-card">
                <span class="bi bi-shield-check feature-icon"></span>
                <h3>Secure & Reliable</h3>
                <p>Your information is protected with industry-standard security measures and privacy controls.</p>
            </div>
        </div>
    </div>

    <div class="cta-section">
        <h2>Ready to Get Started?</h2>
        <p>Join thousands of professionals and enthusiasts who trust EventEase for their event needs.</p>
        <a href="/events" class="btn btn-success btn-lg">
            <span class="bi bi-arrow-right-circle"></span> Explore Events Now
        </a>
    </div>
</div>
