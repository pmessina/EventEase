@using EventEase.Models

<div class="event-card">
    <div class="event-card-header">
        <h3 class="event-name">@EventData.Name</h3>
        <span class="event-category">@EventData.Category</span>
    </div>
    <div class="event-card-body">
        <div class="event-detail">
            <span class="bi bi-calendar-event"></span>
            <span class="event-date">@EventData.Date.ToString("MMM dd, yyyy - h:mm tt")</span>
        </div>
        <div class="event-detail">
            <span class="bi bi-geo-alt"></span>
            <span class="event-location">@EventData.Location</span>
        </div>
        <div class="event-description">
            <p>@EventData.Description</p>
        </div>
        <div class="event-info">
            <div class="event-capacity">
                <span class="bi bi-people"></span>
                <span>Capacity: @EventData.Capacity</span>
            </div>
            <div class="event-price">
                @if (EventData.Price > 0)
                {
                    <span class="price-tag">$@EventData.Price.ToString("F2")</span>
                }
                else
                {
                    <span class="price-tag free">FREE</span>
                }
            </div>
        </div>
    </div>
    <div class="event-card-footer">
        @if (ShowActions)
        {
            <a href="@($"/events/{EventData.Id}")" class="btn btn-primary">View Details</a>
            <a href="@($"/events/{EventData.Id}/register")" class="btn btn-success">Register</a>
        }
    </div>
</div>

@code {
    [Parameter]
    public Event EventData { get; set; } = new Event();

    [Parameter]
    public bool ShowActions { get; set; } = true;
}
